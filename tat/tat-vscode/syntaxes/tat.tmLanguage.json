{
  "name": "TAT",
  "scopeName": "source.tat",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#directives" },
    { "include": "#graftDirectives" },
    { "include": "#keywords" },
    { "include": "#nodeDefinitions" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#metadataKeys" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.tat",
          "match": "//.*$"
        },
        {
          "name": "comment.block.tat",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tat",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.tat",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.tat",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.tat",
              "match": "\\\\."
            }
          ]
        }
      ]
    },

    "directives": {
      "patterns": [
        {
          "name": "keyword.control.directive.tat",
          "match": "@\\b(seed|if|ctx|derive|action|guard|graph|effect)\\b"
        }
      ]
    },

    "graftDirectives": {
      "patterns": [
        {
          "name": "support.function.graft.tat",
          "match": "@graft\\.(branch|bud|leaf|vine|meta|state|progress)\\b"
        },
        {
          "name": "support.function.derive.tat",
          "match": "@derive\\.(state|edge|node|meta|projection)\\b"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.other.tat",
          "match": "\\b(nodes|root|node|key|when|then|else|true|false|null)\\b"
        }
      ]
    },

    "nodeDefinitions": {
      "patterns": [
        {
          "name": "entity.name.type.node.tat",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*=\\s*<\\s*\\{)"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.arrow.tat",
          "match": "<>|\\-\\>"
        },
        {
          "name": "keyword.operator.assignment.tat",
          "match": ":=|="
        },
        {
          "name": "keyword.operator.comparison.tat",
          "match": ">=|<=|==|!=|(?<!-)>|<|-"
        },
        {
          "name": "keyword.operator.logical.tat",
          "match": "\\b(AND|OR|NOT|and|or|not)\\b"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.tat",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },

    "metadataKeys": {
      "patterns": [
        {
          "name": "variable.other.property.tat",
          "match": "\"[a-zA-Z_][a-zA-Z0-9_]*\"(?=\\s*,)"
        }
      ]
    }
  }
}
